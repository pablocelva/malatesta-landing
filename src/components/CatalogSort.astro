---
<div class="catalog-sort">
  <svg class="catalog-sort-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <line x1="4" y1="6" x2="20" y2="6" />
    <line x1="4" y1="12" x2="16" y2="12" />
    <line x1="4" y1="18" x2="12" y2="18" />
  </svg>
  <select id="catalog-sort-select" class="catalog-sort-select">
    <option value="category">Categoria</option>
    <option value="name-asc">Nombre A → Z</option>
    <option value="name-desc">Nombre Z → A</option>
    <option value="price-asc">Menor precio</option>
    <option value="price-desc">Mayor precio</option>
    <option value="available">Disponibles primero</option>
    <option value="newest">Mas recientes</option>
  </select>
</div>

<style>
  .catalog-sort {
    position: relative;
    width: 200px;
  }

  .catalog-sort-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .catalog-sort-select {
    width: 100%;
    padding: 12px 36px 12px 40px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text);
    font-size: var(--text-sm);
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='12' viewBox='0 0 24 24' fill='none' stroke='%23999' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Cpolyline points='6 9 12 15 18 9'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 12px center;
    transition: border-color var(--transition-fast);
  }

  .catalog-sort-select:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .catalog-sort {
      width: 100%;
    }
  }
</style>
