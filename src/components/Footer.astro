---
---
<footer class="footer">
  <div class="container">
    <p class="footer-text">
      La <a href="/" class="footer-highline">Malatesta</a> &copy; {new Date().getFullYear()}
    </p>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--color-border);
  }

  .footer-text {
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .footer-highline {
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  .footer-highline:hover {
    opacity: 0.8;
  }
</style>
